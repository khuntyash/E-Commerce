# syntax=docker/dockerfile:1

# Build the React (Vite) frontend and serve it as static files via nginx,
# proxying /api to the API service.
# Debian (glibc) base is required for the build stage; do NOT use alpine.
FROM node:24-slim AS build

ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH
RUN corepack enable && corepack prepare pnpm@11.8.0 --activate

WORKDIR /app

COPY . .
RUN pnpm install --frozen-lockfile

# vite.config.ts requires PORT and BASE_PATH to be present even for `build`.
ENV NODE_ENV=production
ENV PORT=8080
ENV BASE_PATH=/
RUN pnpm --filter @workspace/zero-ecommerce run build

FROM nginx:1.27-alpine AS runtime
COPY --from=build /app/artifacts/zero-ecommerce/dist/public /usr/share/nginx/html
COPY artifacts/zero-ecommerce/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
