# Main website (E-Commerce) environment template. Copy to .env and edit.

# Postgres connection string (required by the API server and drizzle-kit).
# Local dev uses docker-compose.dev.yml -> port 5433.
DATABASE_URL=postgresql://ecom:ecom_pass@127.0.0.1:5433/ecommerce
# Production (Neon) example — note the required SSL parameter:
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

# API server port (set this in your host/orchestrator in production).
PORT=5050
NODE_ENV=development

# Customer Care
# Shared secret the external app (Label-Cropper) must send as X-Webhook-Secret.
CUSTOMER_CARE_WEBHOOK_SECRET=change-me-to-a-long-random-string
# Token that protects the /admin/customer-care endpoints (sent as X-Admin-Token).
ADMIN_API_TOKEN=change-me-to-another-long-random-string

# Frontend (zero-ecommerce) local dev only:
# BASE_PATH=/
# API_PROXY_TARGET=http://127.0.0.1:5050   # forwards /api to the API server during `vite dev`
